<!DOCTYPE html>
<html lang="id" class="dark">
<%- include('layout/head', { title: 'Cari Anime' }) %>
<body>
    <%- include('layout/navbar', { active: 'search', query: query }) %>
    
    <main class="container-main py-6 max-w-2xl mx-auto">
        <a href="/" class="inline-flex items-center gap-2 text-sm font-semibold text-[#ec4899] hover:text-[#f472b6] transition-colors mb-4">
            <span>←</span> Kembali
        </a>

        <h1 class="text-2xl font-bold text-white mb-4">Cari Anime Di Sini</h1>

        <div class="relative mb-4">
            <input 
                type="text" 
                id="searchInput"
                name="q"
                value="<%= query || '' %>"
                placeholder="Ketik judul anime..."
                class="w-full bg-[#141b2d] rounded-2xl px-5 py-4 pr-12 border border-[#1a2338] focus:border-[#ec4899] transition-all text-white placeholder-[#4a5a7a] text-base outline-none"
                autocomplete="off"
            />
            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-[#6b7a9a]">🔍</span>
        </div>

        <div class="mb-6 select-none">
            <div class="flex justify-center gap-1 mb-1">
                <% 'qwertyuiop'.split('').forEach(char => { %>
                    <button type="button" class="key-btn w-8 h-10 sm:w-10 sm:h-12 rounded-lg bg-[#1a2338] text-white text-sm font-semibold hover:bg-[#2a3348] transition-all active:scale-95" data-char="<%= char %>">
                        <%= char %>
                    </button>
                <% }) %>
            </div>
            <div class="flex justify-center gap-1 mb-1">
                <% 'asdfghjkl'.split('').forEach(char => { %>
                    <button type="button" class="key-btn w-8 h-10 sm:w-10 sm:h-12 rounded-lg bg-[#1a2338] text-white text-sm font-semibold hover:bg-[#2a3348] transition-all active:scale-95" data-char="<%= char %>">
                        <%= char %>
                    </button>
                <% }) %>
            </div>
            <div class="flex justify-center gap-1">
                <% 'zxcvbnm'.split('').forEach(char => { %>
                    <button type="button" class="key-btn w-8 h-10 sm:w-10 sm:h-12 rounded-lg bg-[#1a2338] text-white text-sm font-semibold hover:bg-[#2a3348] transition-all active:scale-95" data-char="<%= char %>">
                        <%= char %>
                    </button>
                <% }) %>
                <button type="button" id="backspaceBtn" class="w-12 h-10 sm:w-16 sm:h-12 rounded-lg bg-[#1a2338] text-white text-sm font-semibold hover:bg-[#2a3348] transition-all active:scale-95 flex items-center justify-center">
                    ←
                </button>
            </div>
        </div>

        <div id="searchResults">
            <% if (query && data && data.length) { %>
                <div class="flex items-center justify-between mb-4">
                    <h2 class="text-lg font-bold text-white">Hasil untuk "<%= query %>"</h2>
                    <span class="text-sm text-[#6b7a9a]"><%= data.length %> ditemukan</span>
                </div>
                <div class="anime-grid">
                    <% data.forEach(item => { %>
                        <a href="/anime/<%= item.slug %>" class="anime-card">
                            <div class="thumb-wrap">
                                <img src="<%= item.img %>" alt="<%= item.title %>" loading="lazy" onerror="this.style.display='none';this.parentElement.classList.add('img-fallback');this.parentElement.innerHTML='<span>'+'<%= item.title %>'.slice(0,20)+'</span>';">
                                <div class="absolute top-2 right-2 bg-black/70 px-2 py-0.5 rounded-lg text-xs font-bold text-white">⭐ <%= item.rating %></div>
                            </div>
                            <div class="info">
                                <h3><%= item.title %></h3>
                                <div class="meta">
                                    <span>Eps <%= item.eps %></span>
                                    <span>•</span>
                                    <span><%= item.year || '-' %></span>
                                </div>
                            </div>
                        </a>
                    <% }) %>
                </div>
            <% } else if (query) { %>
                <div class="text-center py-10">
                    <p class="text-[#6b7a9a]">Tidak ada anime dengan judul "<%= query %>"</p>
                </div>
            <% } else { %>
                <div class="text-center py-10 text-[#6b7a9a]">
                    <p>Mulai ketik untuk mencari anime favoritmu</p>
                </div>
            <% } %>
        </div>
    </main>

    <footer class="footer">
        © 2026 ShiroHub — streaming anime gratis
    </footer>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('searchInput');
            const keyBtns = document.querySelectorAll('.key-btn');
            const backspaceBtn = document.getElementById('backspaceBtn');
            let debounceTimer;

            function redirectSearch(query) {
                if (query.trim().length === 0) {
                    window.location.href = '/search';
                    return;
                }
                window.location.href = '/search?q=' + encodeURIComponent(query.trim());
            }

            searchInput.addEventListener('input', function() {
                const query = this.value;
                clearTimeout(debounceTimer);
                debounceTimer = setTimeout(function() {
                    redirectSearch(query);
                }, 300);
            });

            keyBtns.forEach(btn => {
                btn.addEventListener('click', function() {
                    const char = this.getAttribute('data-char');
                    const currentValue = searchInput.value;
                    searchInput.value = currentValue + char;
                    searchInput.dispatchEvent(new Event('input'));
                });
            });

            backspaceBtn.addEventListener('click', function() {
                const currentValue = searchInput.value;
                searchInput.value = currentValue.slice(0, -1);
                searchInput.dispatchEvent(new Event('input'));
            });

            searchInput.addEventListener('keydown', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    clearTimeout(debounceTimer);
                    redirectSearch(this.value);
                }
            });
        });
    </script>
</body>
</html>
