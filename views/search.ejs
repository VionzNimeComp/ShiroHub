<!DOCTYPE html>
<html lang="id" class="dark">
<%- include('layout/head', { title: 'Cari Anime' }) %>
<body>
    <%- include('layout/navbar', { active: 'search', query: query }) %>
    
    <main class="container-main py-6 max-w-2xl mx-auto">
        <a href="/" class="inline-flex items-center gap-2 text-sm font-semibold text-[#ec4899] hover:text-[#f472b6] transition-colors mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
            Kembali
        </a>

        <div class="mb-8">
            <form action="/search" method="get" class="relative">
                <input 
                    type="text" 
                    name="q"
                    value="<%= query %>"
                    placeholder="Cari Anime Di Sini"
                    class="w-full bg-[#141b2d] rounded-2xl px-5 py-4 pr-20 border border-[#1a2338] focus:border-[#ec4899] transition-all text-white placeholder-[#4a5a7a] text-base outline-none"
                    autocomplete="off"
                    autofocus
                />
                <button type="submit" class="absolute right-2 top-1/2 -translate-y-1/2 btn-primary text-white font-bold px-5 py-2 rounded-xl text-sm">
                    Cari
                </button>
            </form>
        </div>

        <% if (query && query.length > 0) { %>
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-bold text-white">Hasil untuk "<%= query %>"</h2>
                <span class="text-sm text-[#6b7a9a]"><%= data.length %> ditemukan</span>
            </div>

            <% if (data && data.length) { %>
                <div class="anime-grid">
                    <% data.forEach(item => { %>
                        <a href="/anime/<%= item.slug %>" class="anime-card">
                            <div class="thumb-wrap">
                                <img src="<%= item.img %>" alt="<%= item.title %>" loading="lazy" onerror="this.style.display='none';this.parentElement.classList.add('img-fallback');this.parentElement.innerHTML='<span>'+'<%= item.title %>'.slice(0,20)+'</span>';">
                                <div class="absolute top-2 right-2 bg-black/70 px-2 py-0.5 rounded-lg text-xs font-bold text-white">⭐ <%= item.rating %></div>
                            </div>
                            <div class="info">
                                <h3><%= item.title %></h3>
                                <div class="meta">
                                    <span>Eps <%= item.eps %></span>
                                    <span>•</span>
                                    <span><%= item.year || '-' %></span>
                                </div>
                            </div>
                        </a>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="text-center py-12">
                    <p class="text-[#8a9abb]">Tidak ada anime yang cocok dengan "<%= query %>"</p>
                </div>
            <% } %>
        <% } else { %>
            <div class="text-center py-12 text-[#6b7a9a]">
                <p>Mulai ketik untuk mencari anime favoritmu</p>
            </div>
        <% } %>
    </main>

    <footer class="footer">
        © 2026 ShiroHub — streaming anime gratis
    </footer>
</body>
</html>
