<!DOCTYPE html>
<html lang="id" class="dark">
<%- include('layout/head', { title: 'Jadwal Tayang' }) %>
<body>
    <%- include('layout/navbar', { active: 'schedule', query: null }) %>
    
    <main class="container-main py-6 max-w-6xl mx-auto">
        <h1 class="text-2xl font-extrabold text-white mb-4">Jadwal Tayang</h1>
        
        <div class="space-y-3">
            <% if (schedule && schedule.length) { %>
                <% 
                    const dayMap = {
                        'Senin': 'Sen',
                        'Selasa': 'Sel',
                        'Rabu': 'Rab',
                        'Kamis': 'Kam',
                        'Jumat': 'Jum',
                        'Sabtu': 'Sab',
                        'Minggu': 'Min'
                    };
                %>
                <% schedule.forEach((day) => { 
                    const dayShort = dayMap[day.day] || day.day.slice(0,3);
                    const total = day.list ? day.list.length : 0;
                %>
                    <div class="flex gap-4 border-b border-[#1a2338] pb-3 last:border-0">
                        <div class="w-14 flex-shrink-0 pt-0.5">
                            <div class="text-lg font-bold text-[#ec4899]"><%= dayShort %></div>
                            <div class="text-xs text-[#6b7a9a]"><%= total %></div>
                        </div>
                        
                        <div class="flex-1 space-y-2.5">
                            <% if (day.list && day.list.length) { %>
                                <% day.list.forEach(item => { 
                                    const isOngoing = item.status === 'Ongoing';
                                    const statusText = isOngoing ? '✅ Sudah Tayang' : '⏳ Menunggu Update Baru';
                                    const statusColor = isOngoing ? 'text-green-400' : 'text-yellow-400';
                                    const shortTitle = item.title.length > 30 ? item.title.slice(0, 30) + '...' : item.title;
                                    
                                    const ratingDisplay = (item.rating && item.rating !== '0') ? '⭐ ' + item.rating : '⭐ -';
                                %>
                                    <a href="/anime/<%= item.slug %>" class="flex items-center gap-3 hover:bg-[#1a2338] rounded-lg p-1.5 transition-all group">
                                        <div class="w-10 h-14 flex-shrink-0 rounded-md overflow-hidden bg-[#0f1629] border border-[#1a2338]">
                                            <img 
                                                src="<%= item.img %>" 
                                                alt="<%= item.title %>" 
                                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" 
                                                loading="lazy" 
                                                onerror="this.style.display='none';this.parentElement.classList.add('img-fallback','text-[8px]');this.parentElement.innerHTML='<span>No img</span>';"
                                            >
                                        </div>
                                        
                                        <div class="flex-1 min-w-0">
                                            <div class="text-sm font-bold text-white group-hover:text-[#ec4899] transition-colors truncate max-w-[300px] sm:max-w-[400px]">
                                                <%= shortTitle %>
                                            </div>
                                            <div class="flex flex-wrap items-center gap-x-3 gap-y-0.5 text-xs text-[#8a9abb]">
                                                <span>Eps <%= item.eps %></span>
                                                <span><%= ratingDisplay %></span>
                                                <span class="<%= statusColor %> font-medium text-[11px]">
                                                    <%= statusText %>
                                                </span>
                                            </div>
                                        </div>
                                    </a>
                                <% }) %>
                            <% } else { %>
                                <div class="text-xs text-[#6b7a9a] italic py-1">Tidak ada rilis</div>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="text-center py-10 text-[#6b7a9a]">Belum ada jadwal.</div>
            <% } %>
        </div>
    </main>

    <footer class="footer">
        © 2026 ShiroHub — streaming anime gratis
    </footer>
</body>
</html>
