<!DOCTYPE html>
<html lang="id" class="dark">
<%- include('layout/head', { title: 'Jadwal Tayang' }) %>
<body>
    <%- include('layout/navbar', { active: 'schedule', query: null }) %>
    <main class="container-main py-6 max-w-5xl mx-auto">
        <h1 class="text-3xl font-extrabold text-white mb-6">Jadwal Tayang</h1>
        
        <div class="space-y-4">
            <% if (schedule && schedule.length) { %>
                <% 
                    const dayMap = {
                        'Senin': 'Sen',
                        'Selasa': 'Sel',
                        'Rabu': 'Rab',
                        'Kamis': 'Kam',
                        'Jumat': 'Jum',
                        'Sabtu': 'Sab',
                        'Minggu': 'Min'
                    };
                %>
                <% schedule.forEach(day => { %>
                    <div class="flex gap-6 border-b border-[#1a2338] pb-4 last:border-0">
                        <div class="w-16 flex-shrink-0">
                            <span class="text-xl font-bold text-[#ec4899]"><%= dayMap[day.day] || day.day.slice(0,3) %></span>
                        </div>
                        
                        <div class="flex-1 space-y-3">
                            <% if (day.list && day.list.length) { %>
                                <% day.list.forEach(item => { 
                                    const status = item.status === 'Ongoing' ? 'Sudah Tayang' : 'Menunggu Update Baru';
                                    const isOngoing = item.status === 'Ongoing';
                                %>
                                    <div class="flex flex-col">
                                        <!-- Judul -->
                                        <a href="/anime/<%= item.slug %>" class="text-base font-bold text-white hover:text-[#ec4899] transition-colors">
                                            <%= item.title %>
                                        </a>
                                        <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-[#8a9abb] mt-0.5">
                                            <span>Episode <%= item.eps %></span>
                                            <span>⭐ <%= item.rating %>K</span>
                                            <span>⭐ <%= (parseFloat(item.rating) / 1.5).toFixed(2) || '7.00' %></span>
                                            <span class="<%= isOngoing ? 'text-green-400' : 'text-yellow-400' %> font-medium">
                                                <%= isOngoing ? '✅ Sudah Tayang' : '⏳ Menunggu Update Baru' %>
                                            </span>
                                        </div>
                                    </div>
                                <% }) %>
                            <% } else { %>
                                <div class="text-sm text-[#6b7a9a] italic">Tidak ada rilis</div>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="text-center py-10 text-[#6b7a9a]">Belum ada jadwal.</div>
            <% } %>
        </div>
    </main>

    <footer class="footer">
        © 2026 ShiroHub — streaming anime gratis
    </footer>
</body>
</html>
