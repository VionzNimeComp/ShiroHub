<!DOCTYPE html>
<html lang="id" class="dark">
<%- include('layout/head', { title: 'Jadwal Rilis' }) %>
<body>
    <%- include('layout/navbar', { active: 'schedule', query: null }) %>
    
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <h1 class="text-3xl font-extrabold text-white mb-2">Jadwal Rilis</h1>
        <p class="text-[#8a9abb] mb-6">Jadwal rilis anime setiap hari.</p>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            <% if (schedule && schedule.length) { %>
                <% schedule.forEach(day => { %>
                    <div class="rounded-xl bg-[#141b2d] border border-[#1a2338] p-5">
                        <h2 class="text-lg font-bold text-[#ec4899] mb-4 border-b border-[#1a2338] pb-3"><%= day.day %></h2>
                        <ul class="space-y-2">
                            <% day.list.forEach(item => { %>
                                <li>
                                    <a href="/anime/<%= item.slug %>" class="block text-sm text-[#c8d0e0] hover:text-[#ec4899] transition-colors">
                                        <%= item.title %>
                                        <span class="text-xs text-[#6b7a9a] ml-2">Eps <%= item.eps %></span>
                                    </a>
                                </li>
                            <% }) %>
                        </ul>
                        <% if (day.list.length === 0) { %>
                            <p class="text-sm text-[#6b7a9a] italic">Tidak ada rilis</p>
                        <% } %>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-span-full text-center py-10 text-[#6b7a9a]">Belum ada jadwal.</div>
            <% } %>
        </div>
    </main>
    
    <footer class="border-t border-[#1a2338] mt-10 py-6 text-center text-sm text-[#6b7a9a]">
        © 2026 ShiroHub — streaming anime gratis
    </footer>
</body>
</html>
