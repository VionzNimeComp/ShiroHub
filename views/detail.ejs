<!DOCTYPE html>
<html lang="id" class="dark">
<%- include('layout/head', { title: anime.title }) %>
<body>
    <%- include('layout/navbar', { active: 'home', query: null }) %>
    
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <a href="/" class="inline-block text-sm font-semibold text-[#ec4899] hover:text-[#f472b6] mb-4">← Kembali</a>
        
        <div class="grid grid-cols-1 md:grid-cols-[220px,1fr] gap-8">
            <div class="rounded-xl overflow-hidden bg-[#141b2d] border border-[#1a2338]">
                <img src="<%= anime.img %>" alt="<%= anime.title %>" class="w-full aspect-[2/3] object-cover" onerror="this.style.display='none';this.parentElement.classList.add('img-fallback','h-72');this.parentElement.innerHTML='<span class=text-sm font-semibold text-[#4a5a7a]>Gambar tidak tersedia</span>';">
            </div>
            
            <div>
                <h1 class="text-3xl font-extrabold text-white"><%= anime.title %></h1>
                
                <div class="flex flex-wrap items-center gap-4 mt-3 text-sm text-[#8a9abb]">
                    <span><strong class="text-white">Status</strong> <span class="px-2 py-0.5 rounded-lg text-xs font-bold <%= anime.status === 'Ongoing' ? 'badge-ongoing' : 'badge-completed' %> text-white"><%= anime.status %></span></span>
                    <span><strong class="text-white">Tahun</strong> <%= anime.year || '-' %></span>
                    <span><strong class="text-white">Rating</strong> ⭐ <%= anime.rating || '-' %></span>
                </div>
                
                <div class="flex flex-wrap gap-2 mt-4">
                    <% (anime.genres || []).forEach(g => { %>
                        <span class="px-3 py-1 rounded-lg text-xs font-semibold bg-[#1a2338] text-[#8a9abb]"><%= g.title || g %></span>
                    <% }) %>
                </div>
                
                <p class="mt-4 text-[#c8d0e0] leading-relaxed text-sm"><%= anime.desc %></p>
                
                <div class="mt-8">
                    <h2 class="text-xl font-bold text-white">📺 Daftar Episode <span class="text-sm font-normal text-[#6b7a9a]">(<%= (anime.episodes || []).length %> episode)</span></h2>
                    <div class="eps-grid mt-4">
                        <% if (anime.episodes && anime.episodes.length) { %>
                            <% anime.episodes.forEach(e => { %>
                                <a href="/watch/<%= anime.slug %>/<%= e.slug %>" class="block text-center px-3 py-2.5 rounded-xl bg-[#141b2d] border border-[#1a2338] text-sm font-semibold text-[#c8d0e0] hover:border-[#ec4899] hover:bg-[#1a2338] transition-all">
                                    <%= e.title %>
                                </a>
                            <% }) %>
                        <% } else { %>
                            <div class="col-span-full text-center py-6 text-[#6b7a9a]">Belum ada episode.</div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </main>
    
    <footer class="border-t border-[#1a2338] mt-10 py-6 text-center text-sm text-[#6b7a9a]">
        © 2026 ShiroHub — streaming anime gratis
    </footer>
</body>
</html>
