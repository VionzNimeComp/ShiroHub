<!DOCTYPE html>
<html lang="id" class="dark">
<%- include('layout/head', { title: anime.title + ' - Episode ' + episodeNumber }) %>
<body>
    <%- include('layout/navbar', { active: 'home', query: null }) %>
    
    <main class="container-main py-6">
        <a href="/anime/<%= anime.slug %>" class="inline-block text-sm font-semibold text-[#ec4899] hover:text-[#f472b6] transition-colors mb-4">← Kembali ke Detail</a>
        
        <div class="video-wrapper">
            <% if (url) { %>
                <iframe src="<%= url %>" allowfullscreen allow="autoplay; encrypted-media"></iframe>
            <% } else { %>
                <div class="absolute inset-0 flex items-center justify-center text-[#6b7a9a] font-semibold">⚠️ Video tidak tersedia</div>
            <% } %>
        </div>
        
        <div class="watch-nav">
            <h2 class="text-lg font-bold text-white"><%= anime.title %> — Episode <span class="text-[#ec4899]"><%= episodeNumber %></span></h2>
            <div class="nav-buttons">
                <% 
                    const epsList = anime.episodes || [];
                    const currentIndex = epsList.findIndex(e => e.id == currentEps);
                    const prev = currentIndex > 0 ? epsList[currentIndex - 1] : null;
                    const next = currentIndex < epsList.length - 1 ? epsList[currentIndex + 1] : null;
                %>
                <% if (prev) { %>
                    <a href="/watch/<%= anime.slug %>/<%= prev.slug %>">◀ Prev</a>
                <% } else { %>
                    <span>◀ Prev</span>
                <% } %>
                <% if (next) { %>
                    <a href="/watch/<%= anime.slug %>/<%= next.slug %>">Next ▶</a>
                <% } else { %>
                    <span>Next ▶</span>
                <% } %>
            </div>
        </div>
        
        <div class="mt-6">
            <h3 class="text-lg font-bold text-white mb-3">📺 Semua Episode</h3>
            <div class="eps-grid">
                <% epsList.forEach(e => { %>
                    <a href="/watch/<%= anime.slug %>/<%= e.slug %>" class="block text-center px-3 py-2 rounded-xl border text-sm font-semibold transition-all <%= e.id == currentEps ? 'border-[#ec4899] bg-[#ec4899]/10 text-white' : 'border-[#1a2338] bg-[#141b2d] text-[#c8d0e0] hover:border-[#ec4899] hover:bg-[#1a2338]' %>">
                        <%= e.title %>
                    </a>
                <% }) %>
            </div>
        </div>
    </main>

    <footer class="footer">
        © 2026 ShiroHub — streaming anime gratis
    </footer>
</body>
</html>
