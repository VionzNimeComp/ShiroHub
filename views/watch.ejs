<!DOCTYPE html>
<html lang="id" class="dark">
<%- include('layout/head', { title: anime.title + ' - Episode ' + currentEps }) %>
<body>
    <%- include('layout/navbar', { active: 'home', query: null }) %>
    
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <a href="/anime/<%= anime.slug %>" class="inline-block text-sm font-semibold text-[#ec4899] hover:text-[#f472b6] mb-4">← Kembali ke Detail</a>
        
        <div class="video-wrapper">
            <% if (url) { %>
                <iframe src="<%= url %>" allowfullscreen allow="autoplay; encrypted-media"></iframe>
            <% } else { %>
                <div class="absolute inset-0 flex items-center justify-center text-[#6b7a9a] font-semibold">⚠️ Video tidak tersedia</div>
            <% } %>
        </div>
        
        <div class="flex flex-wrap items-center justify-between gap-4 mt-4">
            <h2 class="text-lg font-bold text-white"><%= anime.title %> — Episode <span class="text-[#ec4899]"><%= currentEps %></span></h2>
            <div class="flex items-center gap-3">
                <% 
                    const epsList = anime.episodes || [];
                    const currentIndex = epsList.findIndex(e => e.id == currentEps);
                    const prev = currentIndex > 0 ? epsList[currentIndex - 1] : null;
                    const next = currentIndex < epsList.length - 1 ? epsList[currentIndex + 1] : null;
                %>
                <% if (prev) { %>
                    <a href="/watch/<%= anime.slug %>/<%= prev.slug %>" class="px-5 py-2 rounded-xl bg-[#141b2d] border border-[#1a2338] text-sm font-semibold text-white hover:border-[#ec4899] hover:bg-[#1a2338] transition-all">◀ Prev</a>
                <% } else { %>
                    <span class="px-5 py-2 rounded-xl bg-[#0f1629] border border-[#1a2338] text-sm font-semibold text-[#4a5a7a] opacity-50 cursor-not-allowed">◀ Prev</span>
                <% } %>
                <% if (next) { %>
                    <a href="/watch/<%= anime.slug %>/<%= next.slug %>" class="px-5 py-2 rounded-xl bg-[#141b2d] border border-[#1a2338] text-sm font-semibold text-white hover:border-[#ec4899] hover:bg-[#1a2338] transition-all">Next ▶</a>
                <% } else { %>
                    <span class="px-5 py-2 rounded-xl bg-[#0f1629] border border-[#1a2338] text-sm font-semibold text-[#4a5a7a] opacity-50 cursor-not-allowed">Next ▶</span>
                <% } %>
            </div>
        </div>
        
        <div class="mt-6">
            <h3 class="text-lg font-bold text-white mb-3">📺 Semua Episode</h3>
            <div class="eps-grid">
                <% epsList.forEach(e => { %>
                    <a href="/watch/<%= anime.slug %>/<%= e.slug %>" class="block text-center px-3 py-2 rounded-xl border text-sm font-semibold transition-all <%= e.id == currentEps ? 'border-[#ec4899] bg-[#ec4899]/10 text-white' : 'border-[#1a2338] bg-[#141b2d] text-[#c8d0e0] hover:border-[#ec4899] hover:bg-[#1a2338]' %>">
                        <%= e.title %>
                    </a>
                <% }) %>
            </div>
        </div>
    </main>
    
    <footer class="border-t border-[#1a2338] mt-10 py-6 text-center text-sm text-[#6b7a9a]">
        © 2026 ShiroHub — streaming anime gratis
    </footer>
</body>
</html>
