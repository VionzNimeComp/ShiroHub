<!DOCTYPE html>
<html lang="id" class="dark">
<%- include('layout/head', { title: 'Beranda' }) %>
<body>
    <%- include('layout/navbar', { active: 'home', query: null }) %>
    
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <div class="relative rounded-2xl overflow-hidden mb-6 bg-gradient-to-r from-[#0f1629] to-[#1a2338] border border-[#1a2338] p-8">
            <div class="relative z-10">
                <h1 class="text-3xl font-extrabold text-white">Temukan Anime Favoritmu</h1>
                <p class="text-[#8a9abb] mt-2">Streaming anime subtitle Indonesia gratis, update setiap hari.</p>
            </div>
        </div>

        <div class="max-w-2xl mx-auto mb-8">
            <div class="relative">
                <input 
                    type="text" 
                    id="searchInput" 
                    placeholder="Cari anime favoritmu..." 
                    class="w-full bg-[#141b2d] rounded-2xl px-5 py-4 pr-14 border border-[#1a2338] focus:border-[#ec4899] transition-all text-white placeholder-[#4a5a7a] text-base outline-none"
                    autocomplete="off"
                />
                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-[#6b7a9a] text-sm">🔍</span>
            </div>
            <p class="text-center text-xs text-[#6b7a9a] mt-2">Ketik untuk mencari anime — langsung menuju hasil</p>
        </div>

        <section class="mb-10">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-xl font-bold text-white">Sedang Tayang</h2>
            </div>
            <div class="anime-grid">
                <% if (data.ongoing && data.ongoing.length) { %>
                    <% data.ongoing.slice(0, 12).forEach(item => { %>
                        <a href="/anime/<%= item.slug %>" class="card-hover rounded-xl overflow-hidden bg-[#141b2d] border border-[#1a2338] group">
                            <div class="relative aspect-[2/3] overflow-hidden bg-[#0f1629]">
                                <img src="<%= item.img %>" alt="<%= item.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" onerror="this.style.display='none';this.parentElement.classList.add('img-fallback');this.parentElement.innerHTML='<span class=text-sm font-semibold>'+'<%= item.title %>'.slice(0,20)+'</span>';">
                                <div class="absolute top-2 right-2 bg-black/60 px-2 py-1 rounded-lg text-xs font-bold text-white">⭐ <%= item.rating %></div>
                                <% if (item.status === 'Ongoing') { %>
                                    <span class="absolute bottom-2 left-2 text-xs font-bold px-2 py-1 rounded-lg badge-ongoing text-white">Ongoing</span>
                                <% } else if (item.status === 'Completed') { %>
                                    <span class="absolute bottom-2 left-2 text-xs font-bold px-2 py-1 rounded-lg badge-completed text-white">Completed</span>
                                <% } %>
                            </div>
                            <div class="p-3">
                                <h3 class="text-sm font-semibold text-white line-clamp-2"><%= item.title %></h3>
                                <div class="flex items-center gap-3 mt-1 text-xs text-[#6b7a9a]">
                                    <span>Eps <%= item.eps %></span>
                                    <span>•</span>
                                    <span><%= item.year || '-' %></span>
                                </div>
                            </div>
                        </a>
                    <% }) %>
                <% } else { %>
                    <div class="col-span-full text-center py-10 text-[#6b7a9a]">Belum ada anime tayang.</div>
                <% } %>
            </div>
        </section>

        <section class="mb-10">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-xl font-bold text-white">Rekomendasi</h2>
            </div>
            <div class="anime-grid">
                <% if (data.recommend && data.recommend.length) { %>
                    <% data.recommend.slice(0, 12).forEach(item => { %>
                        <a href="/anime/<%= item.slug %>" class="card-hover rounded-xl overflow-hidden bg-[#141b2d] border border-[#1a2338] group">
                            <div class="relative aspect-[2/3] overflow-hidden bg-[#0f1629]">
                                <img src="<%= item.img %>" alt="<%= item.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" onerror="this.style.display='none';this.parentElement.classList.add('img-fallback');this.parentElement.innerHTML='<span class=text-sm font-semibold>'+'<%= item.title %>'.slice(0,20)+'</span>';">
                                <div class="absolute top-2 right-2 bg-black/60 px-2 py-1 rounded-lg text-xs font-bold text-white">⭐ <%= item.rating %></div>
                            </div>
                            <div class="p-3">
                                <h3 class="text-sm font-semibold text-white line-clamp-2"><%= item.title %></h3>
                                <div class="flex items-center gap-3 mt-1 text-xs text-[#6b7a9a]">
                                    <span>Eps <%= item.eps %></span>
                                    <span>•</span>
                                    <span><%= item.year || '-' %></span>
                                </div>
                            </div>
                        </a>
                    <% }) %>
                <% } else { %>
                    <div class="col-span-full text-center py-10 text-[#6b7a9a]">Belum ada rekomendasi.</div>
                <% } %>
            </div>
        </section>

        <section>
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-xl font-bold text-white">Jadwal Hari Ini</h2>
                <a href="/schedule" class="text-sm font-semibold text-[#ec4899] hover:text-[#f472b6]">Lihat semua →</a>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <% 
                    const dayMap = ['Minggu', 'Senin', 'Selasa', 'Rabu', 'Kamis', 'Jumat', 'Sabtu'];
                    const today = dayMap[new Date().getDay()];
                    const todaySchedule = data.schedule.find(s => s.day === today);
                %>
                <% if (todaySchedule && todaySchedule.list.length) { %>
                    <% todaySchedule.list.slice(0, 8).forEach(item => { %>
                        <a href="/anime/<%= item.slug %>" class="card-hover rounded-xl p-4 bg-[#141b2d] border border-[#1a2338]">
                            <h4 class="text-sm font-semibold text-white line-clamp-2"><%= item.title %></h4>
                            <div class="flex items-center gap-2 mt-2 text-xs text-[#6b7a9a]">
                                <span>Eps <%= item.eps %></span>
                                <span>•</span>
                                <span>⭐ <%= item.rating %></span>
                            </div>
                        </a>
                    <% }) %>
                <% } else { %>
                    <div class="col-span-full text-center py-6 text-[#6b7a9a]">Tidak ada rilis hari ini.</div>
                <% } %>
            </div>
        </section>
    </main>

    <footer class="border-t border-[#1a2338] mt-10 py-6 text-center text-sm text-[#6b7a9a]">
        © 2026 ShiroHub — streaming anime gratis
    </footer>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('searchInput');
            if (!searchInput) return;

            let debounceTimer;

            searchInput.addEventListener('input', function() {
                const query = this.value.trim();
                
                clearTimeout(debounceTimer);

                if (query.length === 0) return;

                debounceTimer = setTimeout(function() {
                    window.location.href = '/search?q=' + encodeURIComponent(query);
                }, 500);
            });

            searchInput.addEventListener('keydown', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    const query = this.value.trim();
                    if (query.length > 0) {
                        window.location.href = '/search?q=' + encodeURIComponent(query);
                    }
                }
            });
        });
    </script>
</body>
</html>
