<!DOCTYPE html>
<html lang="id" class="dark">
<%- include('layout/head', { title: 'Beranda' }) %>
<body>
    <%- include('layout/navbar', { active: 'home', query: null }) %>
    
    <main class="container-main py-6">
        <div class="relative rounded-2xl overflow-hidden mb-6 bg-gradient-to-r from-[#0f1629] to-[#1a2338] border border-[#1a2338] p-6 sm:p-8 text-center sm:text-left">
            <div class="relative z-10">
                <h1 class="text-2xl sm:text-3xl font-extrabold text-white">Temukan Anime Favoritmu</h1>
                <p class="text-[#8a9abb] mt-1 text-sm sm:text-base">Streaming anime subtitle Indonesia gratis, update setiap hari.</p>
            </div>
        </div>

        <div class="max-w-2xl mx-auto mb-8">
            <form action="/search" method="get" class="relative">
                <input 
                    type="text" 
                    name="q"
                    id="searchInput"
                    placeholder="Cari anime favoritmu..." 
                    class="w-full bg-[#141b2d] rounded-2xl px-5 py-4 pr-14 border border-[#1a2338] focus:border-[#ec4899] transition-all text-white placeholder-[#4a5a7a] text-base outline-none"
                    autocomplete="off"
                />
                <button type="submit" class="absolute right-2 top-1/2 -translate-y-1/2 btn-primary text-white font-bold px-4 py-2 rounded-xl text-sm">
                    Cari
                </button>
            </form>
            <p class="text-center text-xs text-[#6b7a9a] mt-2">Ketik judul anime lalu tekan Enter atau klik Cari</p>
        </div>

        <section class="mb-10">
            <h2 class="text-xl font-bold text-white mb-4">Sedang Tayang</h2>
            <div class="anime-grid">
                <% if (data.ongoing && data.ongoing.length) { %>
                    <% data.ongoing.slice(0, 12).forEach(item => { %>
                        <a href="/anime/<%= item.slug %>" class="anime-card">
                            <div class="thumb-wrap">
                                <img src="<%= item.img %>" alt="<%= item.title %>" loading="lazy" onerror="this.style.display='none';this.parentElement.classList.add('img-fallback');this.parentElement.innerHTML='<span>'+'<%= item.title %>'.slice(0,20)+'</span>';">
                                <div class="absolute top-2 right-2 bg-black/70 px-2 py-0.5 rounded-lg text-xs font-bold text-white">⭐ <%= item.rating %></div>
                                <% if (item.status === 'Ongoing') { %>
                                    <span class="absolute bottom-2 left-2 text-xs font-bold px-2 py-0.5 rounded-lg badge-ongoing text-white">Ongoing</span>
                                <% } else if (item.status === 'Completed') { %>
                                    <span class="absolute bottom-2 left-2 text-xs font-bold px-2 py-0.5 rounded-lg badge-completed text-white">Completed</span>
                                <% } %>
                            </div>
                            <div class="info">
                                <h3><%= item.title %></h3>
                                <div class="meta">
                                    <span>Eps <%= item.eps %></span>
                                    <span>•</span>
                                    <span><%= item.year || '-' %></span>
                                </div>
                            </div>
                        </a>
                    <% }) %>
                <% } else { %>
                    <div class="col-span-full text-center py-10 text-[#6b7a9a]">Belum ada anime tayang.</div>
                <% } %>
            </div>
        </section>

        <section class="mb-10">
            <h2 class="text-xl font-bold text-white mb-4">Rekomendasi</h2>
            <div class="anime-grid">
                <% if (data.recommend && data.recommend.length) { %>
                    <% data.recommend.slice(0, 12).forEach(item => { %>
                        <a href="/anime/<%= item.slug %>" class="anime-card">
                            <div class="thumb-wrap">
                                <img src="<%= item.img %>" alt="<%= item.title %>" loading="lazy" onerror="this.style.display='none';this.parentElement.classList.add('img-fallback');this.parentElement.innerHTML='<span>'+'<%= item.title %>'.slice(0,20)+'</span>';">
                                <div class="absolute top-2 right-2 bg-black/70 px-2 py-0.5 rounded-lg text-xs font-bold text-white">⭐ <%= item.rating %></div>
                            </div>
                            <div class="info">
                                <h3><%= item.title %></h3>
                                <div class="meta">
                                    <span>Eps <%= item.eps %></span>
                                    <span>•</span>
                                    <span><%= item.year || '-' %></span>
                                </div>
                            </div>
                        </a>
                    <% }) %>
                <% } else { %>
                    <div class="col-span-full text-center py-10 text-[#6b7a9a]">Belum ada rekomendasi.</div>
                <% } %>
            </div>
        </section>

        <section>
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-xl font-bold text-white">Jadwal Hari Ini</h2>
                <a href="/schedule" class="text-sm font-semibold text-[#ec4899] hover:text-[#f472b6] transition-colors">Lihat semua →</a>
            </div>
            <div class="schedule-grid">
                <% 
                    const dayMap = ['Minggu', 'Senin', 'Selasa', 'Rabu', 'Kamis', 'Jumat', 'Sabtu'];
                    const today = dayMap[new Date().getDay()];
                    const todaySchedule = data.schedule.find(s => s.day === today);
                %>
                <% if (todaySchedule && todaySchedule.list.length) { %>
                    <% todaySchedule.list.slice(0, 8).forEach(item => { %>
                        <a href="/anime/<%= item.slug %>" class="card-hover rounded-xl p-4 bg-[#141b2d] border border-[#1a2338]">
                            <h4 class="text-sm font-semibold text-white line-clamp-2"><%= item.title %></h4>
                            <div class="flex items-center gap-2 mt-2 text-xs text-[#6b7a9a]">
                                <span>Eps <%= item.eps %></span>
                                <span>•</span>
                                <span>⭐ <%= item.rating %></span>
                            </div>
                        </a>
                    <% }) %>
                <% } else { %>
                    <div class="col-span-full text-center py-6 text-[#6b7a9a]">Tidak ada rilis hari ini.</div>
                <% } %>
            </div>
        </section>
    </main>

    <footer class="footer">
        © 2026 ShiroHub — streaming anime gratis
    </footer>
</body>
</html>
